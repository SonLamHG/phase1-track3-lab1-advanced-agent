# Copy this file to `.env` and fill in your values. Never commit the real .env.

# Backend selection: "mock" (default, free) or "openai" (real LLM, billed)
LLM_PROVIDER=mock

# OpenAI (required when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-key-here

# Models. For reasoning models (gpt-5-nano, gpt-5-mini, o4-mini, ...) temperature
# is ignored and LLM_REASONING_EFFORT is used instead.
LLM_ACTOR_MODEL=gpt-5-nano
LLM_EVAL_MODEL=gpt-5-nano
LLM_REFLECT_MODEL=gpt-5-nano

# Generation settings
LLM_TEMPERATURE=0.0
LLM_MAX_RETRIES=3
LLM_REASONING_EFFORT=low   # minimal | low | medium | high
